# AI Coding Base Setup - Required API Keys
# Copy to ~/.aicodingsetup/.secrets.env or run install.sh to be prompted

FIRECRAWL_API_KEY=
BRAVE_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# gh CLI auth. Exported into every shell by configs/bash/env.sh; GH_TOKEN
# outranks the keyring and ~/.config/gh, so gh is authed with no gh mount.
# Must be listed here or install.sh's secrets rewrite would drop it.
GH_TOKEN=
