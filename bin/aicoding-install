#!/usr/bin/env bash
# aicoding-install — pull the latest released blueprint and re-run the full
# installer. Complements aicoding-sync: sync reconciles what install already
# provisioned; this re-runs provisioning itself (apt prereqs, tool bootstrap
# incl. codex, templates, tmux plugins, playwright, secrets prompt) — and
# --force-reinstall nukes drift by deleting the manifest first.
set -uo pipefail
SCRIPT_REAL=$(readlink -f "$0"); SCRIPT_DIR=$(dirname "$(dirname "$SCRIPT_REAL")")
: "${AICODING_BLUEPRINT_CLONE:=/tmp/aicoding}"
. "$SCRIPT_DIR/lib/blueprint-source.sh"
aicoding_parse_blueprint_args aicoding-install "$@" || exit $?
for arg in "${AICODING_REMAINING_ARGS[@]}"; do
  case "$arg" in
    -h|--help)
      echo "usage: aicoding-install [--blueprint PATH] [--force-reinstall]"
      echo "  --blueprint PATH  install from this local Git checkout verbatim (never fetch or reset it)"
      exit 0
      ;;
  esac
done
# Bring the tracking clone current (fail-open: offline falls back to the
# cached clone). refresh_blueprint lives in lib/sync.sh; prefer the clone's
# copy, fall back to the install dir's.
if [ -f "$AICODING_BLUEPRINT_CLONE/lib/sync.sh" ]; then
  . "$AICODING_BLUEPRINT_CLONE/lib/sync.sh"
elif [ -f "$SCRIPT_DIR/lib/sync.sh" ]; then
  . "$SCRIPT_DIR/lib/sync.sh"
fi
if command -v refresh_blueprint >/dev/null 2>&1; then
  refresh_blueprint || exit $?
fi
if [ -f "$AICODING_BLUEPRINT_CLONE/install.sh" ]; then
  exec bash "$AICODING_BLUEPRINT_CLONE/install.sh" "${AICODING_REMAINING_ARGS[@]}"
fi
exec bash "$SCRIPT_DIR/install.sh" "${AICODING_REMAINING_ARGS[@]}"
