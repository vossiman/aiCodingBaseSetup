#!/usr/bin/env bash
# aicoding-paseo-daemon — manage the per-pod paseo daemon.
#   --print-home  print PASEO_HOME for this workspace and exit
#   --ensure      seed config + start daemon if not running (fail-open)
#   pair          print the pairing QR/link (for dvw TUI / manual use)
# Per-pod state: ~/.aicodingsetup/paseo/<workspace-id>/ — inside the shared
# bind mount, so the daemon keypair (pairing identity) survives rebuilds and
# is never shared between pods.
set -uo pipefail

TEMPLATE="$HOME/.aicodingsetup/templates/paseo-config.json"
WORKSPACES_DIR="${AICODING_WORKSPACES_DIR:-/workspaces}"

_workspace_id() {
  if [[ -n "${DEVPOD_WORKSPACE_ID:-}" ]]; then
    printf '%s' "$DEVPOD_WORKSPACE_ID"; return 0
  fi
  # Fallback: the single checkout under /workspaces names the workspace.
  local dirs=()
  for d in "$WORKSPACES_DIR"/*/; do [[ -d "$d" ]] && dirs+=("$(basename "$d")"); done
  if (( ${#dirs[@]} == 1 )); then printf '%s' "${dirs[0]}"; return 0; fi
  return 1
}

_paseo_home() {
  local id
  id=$(_workspace_id) || return 1
  printf '%s' "$HOME/.aicodingsetup/paseo/$id"
}

# The pod's project directory — the in-container checkout under /workspaces.
_workspace_dir() {
  local id
  id=$(_workspace_id) || return 1
  printf '%s' "$WORKSPACES_DIR/$id"
}

cmd_print_home() {
  local home
  home=$(_paseo_home) || { echo "aicoding-paseo-daemon: cannot derive workspace id" >&2; return 1; }
  echo "$home"
}

_daemon_running() {
  # status exits 0 even when down — pidfile is the only reliable signal
  local home="$1" pidfile pid
  pidfile="$home/paseo.pid"
  if [[ -f "$pidfile" ]]; then
    pid=$(grep -om1 '"pid":[0-9]*' "$pidfile" | grep -o '[0-9]*')
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null && return 0
  fi
  return 1
}

# Register the pod's project dir as a paseo project so it shows up in the app
# sidebar without manual setup. Uses the daemon's openProject (idempotent —
# dedups by directory, no agent started) via the bundled-CLI helper. Fail-open
# throughout; the registry file is the success signal so we retry briefly while
# a just-started daemon comes up. Keeps paseo and tmux separate — this only
# registers the project, it does not start a session.
_register_project() {
  command -v node >/dev/null 2>&1 || return 0   # fail-open: no node
  local home="$1" dir self
  dir=$(_workspace_dir) || return 0
  [[ -d "$dir" ]] || return 0
  self=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
  [[ -f "$self/aicoding-paseo-open-project.mjs" ]] || return 0
  local i
  for i in 1 2 3; do
    PASEO_HOME="$home" node "$self/aicoding-paseo-open-project.mjs" "$dir" >/dev/null 2>&1 || true
    [[ -f "$home/projects/projects.json" ]] && return 0
    sleep 2
  done
  return 0
}

cmd_ensure() {
  command -v paseo >/dev/null 2>&1 || return 0          # fail-open: not installed
  local home
  home=$(_paseo_home) || return 0                        # fail-open: no workspace id
  mkdir -p "$home"
  # Config is fully managed: copy template whenever content differs.
  if [[ -f "$TEMPLATE" ]] && ! cmp -s "$TEMPLATE" "$home/config.json" 2>/dev/null; then
    cp "$TEMPLATE" "$home/config.json"
  fi
  # Start iff not running. Real paseo daemon status always exits 0 — use pid file.
  if ! _daemon_running "$home"; then
    PASEO_HOME="$home" paseo daemon start >/dev/null 2>&1 || true
  fi
  _register_project "$home"
  return 0
}

cmd_pair() {
  command -v paseo >/dev/null 2>&1 || { echo "aicoding-paseo-daemon: paseo not installed in this pod" >&2; return 1; }
  local home
  home=$(_paseo_home) || { echo "aicoding-paseo-daemon: cannot derive workspace id" >&2; return 1; }
  PASEO_HOME="$home" exec paseo daemon pair
}

case "${1:-}" in
  --print-home) cmd_print_home ;;
  --ensure)     cmd_ensure ;;
  pair)         cmd_pair ;;
  *) echo "usage: $(basename "$0") --print-home | --ensure | pair" >&2; exit 2 ;;
esac
