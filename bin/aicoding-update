#!/usr/bin/env bash
set -euo pipefail

# Resolve the blueprint directory: prefer the existing clone at
# $AICODING_BLUEPRINT_CLONE (default /tmp/aicoding); refresh it from git.
# Source the library from the resolved blueprint dir.

SCRIPT_REAL=$(readlink -f "$0")
SCRIPT_DIR=$(dirname "$(dirname "$SCRIPT_REAL")")

: "${AICODING_BLUEPRINT_CLONE:=/tmp/aicoding}"
: "${AICODING_BLUEPRINT_REMOTE:=https://github.com/vossiman/aiCodingBaseSetup}"

ARG_DRY_RUN=0
ARG_YES=0
for arg in "$@"; do
  case "$arg" in
    --dry-run) ARG_DRY_RUN=1 ;;
    --yes)     ARG_YES=1 ;;
    -h|--help)
      cat <<EOF
Usage: aicoding-update [--dry-run] [--yes]
  --dry-run  Show what would change, write nothing.
  --yes      Skip the y/N confirm prompt.
EOF
      exit 0
      ;;
    *) echo "unknown argument: $arg" >&2; exit 2 ;;
  esac
done

refresh_blueprint() {
  if [[ -d "$AICODING_BLUEPRINT_CLONE/.git" ]]; then
    # Only hard-reset if we could actually fetch fresh refs. Otherwise
    # leave the working tree alone — in particular, never wipe local
    # state on the fallback path, which would clobber test setups and
    # any user-staged blueprint experiments.
    if git -C "$AICODING_BLUEPRINT_CLONE" fetch --quiet origin 2>/dev/null; then
      git -C "$AICODING_BLUEPRINT_CLONE" reset --hard --quiet origin/main 2>/dev/null || true
    else
      echo "could not fetch blueprint — using cached clone" >&2
    fi
  elif [[ ! -d "$AICODING_BLUEPRINT_CLONE" ]]; then
    git clone --quiet "$AICODING_BLUEPRINT_REMOTE" "$AICODING_BLUEPRINT_CLONE"
  fi
  # We always source from the clone, so its current state is what's used.
}

refresh_blueprint
. "$AICODING_BLUEPRINT_CLONE/lib/blueprint-deploy.sh"

if [[ ! -f "$AICODING_MANIFEST" ]]; then
  echo "aicoding-update: no manifest at $AICODING_MANIFEST" >&2
  echo "Run install.sh first to provision this container." >&2
  exit 1
fi

OLD_COMMIT=$(jq -r '.blueprint_commit // "unknown"' "$AICODING_MANIFEST")
NEW_COMMIT=$(git -C "$AICODING_BLUEPRINT_CLONE" rev-parse --short HEAD 2>/dev/null || echo unknown)

echo "Blueprint: ${OLD_COMMIT} -> ${NEW_COMMIT}"

# Classification: walk union of manifest entries and blueprint inventory.
declare -A FILE_MODE FILE_SOURCE
declare -A BUCKETS

# Load blueprint inventory by sourcing the same MANAGED_* declarations
# install.sh uses. Reuse: extract them from the cloned install.sh.
# Simpler approach: hardcode the file list here (must stay in sync).
MANAGED_OVERWRITE_FILES=(
  "$HOME/.tmux.conf|overwrite|configs/tmux/tmux.conf"
  "$HOME/.claude/hooks/custom-statusline.js|overwrite|configs/claude/hooks/custom-statusline.js"
  "$HOME/.bashrc.d/aicoding-env.sh|overwrite|configs/bash/env.sh"
  "$HOME/.bashrc.d/aicoding-ssh-auth-sock.sh|overwrite|configs/bash/ssh-auth-sock.sh"
)
MANAGED_MERGE_FILES=(
  "$HOME/.claude/settings.json|merge|configs/claude/settings.json"
  "$HOME/.config/opencode/opencode.json|merge|configs/opencode/opencode.json"
)
BASHRC_BLOCK_START='# >>> aicoding managed block — do not edit between markers >>>'
BASHRC_BLOCK_END='# <<< aicoding managed block <<<'

classify_all() {
  local entry dest mode source
  # Blueprint-side files.
  for entry in "${MANAGED_OVERWRITE_FILES[@]}" "${MANAGED_MERGE_FILES[@]}"; do
    IFS='|' read -r dest mode source <<<"$entry"
    FILE_MODE[$dest]=$mode
    FILE_SOURCE[$dest]=$source
    local bucket
    bucket=$(classify_file "$dest" "$AICODING_BLUEPRINT_CLONE/$source" "$mode")
    BUCKETS[$dest]=$bucket
  done

  # Files in manifest but absent from blueprint inventory → to_remove.
  local manifest_files
  manifest_files=$(jq -r '.files | keys[]' "$AICODING_MANIFEST")
  while IFS= read -r dest; do
    [[ -z "$dest" ]] && continue
    [[ -z "${FILE_MODE[$dest]:-}" ]] && BUCKETS[$dest]=to_remove
  done <<<"$manifest_files"

  # Enumerate skills in blueprint clone.
  local skill_dir skill_name
  for skill_dir in "$AICODING_BLUEPRINT_CLONE/skills"/*/; do
    [[ ! -d "$skill_dir" ]] && continue
    skill_name=$(basename "$skill_dir")
    dest="$HOME/.claude/skills/$skill_name/SKILL.md"
    source="skills/$skill_name/SKILL.md"
    FILE_MODE[$dest]=overwrite
    FILE_SOURCE[$dest]=$source
    BUCKETS[$dest]=$(classify_file "$dest" "$AICODING_BLUEPRINT_CLONE/$source" overwrite)
  done
}

classify_all

# Summary tallies for the dry-run output.
declare -A COUNT
COUNT[up_to_date]=0
COUNT[will_update]=0
COUNT[drifted_but_aligned]=0
COUNT[drifted_and_updating]=0
COUNT[new_file]=0
COUNT[to_remove]=0
COUNT[merge]=0

for dest in "${!BUCKETS[@]}"; do
  b=${BUCKETS[$dest]}
  COUNT[$b]=$(( ${COUNT[$b]} + 1 ))
done

if [[ $ARG_DRY_RUN -eq 1 ]]; then
  for b in up_to_date will_update drifted_but_aligned drifted_and_updating new_file to_remove merge; do
    echo "  ${COUNT[$b]} $b"
  done
  exit 0
fi

print_summary() {
  echo
  echo "  ${COUNT[up_to_date]} up to date"

  if (( COUNT[will_update] > 0 )); then
    echo "  ${COUNT[will_update]} will update         (no drift):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == will_update ]] && echo "      $dest"
    done
  fi

  if (( COUNT[drifted_and_updating] > 0 )); then
    echo "  ${COUNT[drifted_and_updating]} needs your decision (you've modified, blueprint also changed):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} != drifted_and_updating ]] && continue
      echo "      $dest"
      local src="$AICODING_BLUEPRINT_CLONE/${FILE_SOURCE[$dest]}"
      diff -u --label "your version" --label "blueprint version" "$dest" "$src" \
        | sed 's/^/        /' || true
    done
  fi

  if (( COUNT[to_remove] > 0 )); then
    echo "  ${COUNT[to_remove]} to remove           (no longer in blueprint):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == to_remove ]] && echo "      $dest"
    done
  fi

  if (( COUNT[new_file] > 0 )); then
    echo "  ${COUNT[new_file]} new files           (will be deployed):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == new_file ]] && echo "      $dest"
    done
  fi

  if (( COUNT[merge] > 0 )); then
    echo "  ${COUNT[merge]} merge target(s)     (will re-merge, additions preserved):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == merge ]] && echo "      $dest"
    done
  fi

  echo
}

print_summary

# Nothing actionable?
if (( COUNT[will_update] + COUNT[drifted_and_updating] + COUNT[new_file] + COUNT[to_remove] + COUNT[merge] == 0 )); then
  echo "Nothing to do."
  exit 0
fi

if [[ $ARG_YES -ne 1 ]]; then
  # `read -p` only prints the prompt to a terminal; for piped/redirected
  # stdin (tests, CI) we still want the prompt text visible in the log.
  printf 'Apply? [y/N] '
  read -r answer
  case "$answer" in
    y|Y|yes) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

manifest_stage_begin

backup_drifted() {
  local dest=$1
  local stamp
  stamp=$(date +%Y%m%d-%H%M%S)
  cp "$dest" "$dest.bak.$stamp"
  echo "      backup: $dest.bak.$stamp"
}

apply_all() {
  local dest src bucket
  for dest in "${!BUCKETS[@]}"; do
    bucket=${BUCKETS[$dest]}
    src="$AICODING_BLUEPRINT_CLONE/${FILE_SOURCE[$dest]:-}"

    case "$bucket" in
      up_to_date)
        : ;;
      will_update)
        deploy_overwrite_file "$src" "$dest" "${FILE_SOURCE[$dest]}"
        echo "      updated: $dest"
        ;;
      drifted_and_updating)
        backup_drifted "$dest"
        deploy_overwrite_file "$src" "$dest" "${FILE_SOURCE[$dest]}"
        echo "      updated (with backup): $dest"
        ;;
      drifted_but_aligned)
        # Refresh hash only.
        local h
        h=$(compute_hash "$dest")
        manifest_set_file "$dest" \
          "$(jq -n --arg s "${FILE_SOURCE[$dest]}" --arg h "$h" \
              '{mode:"overwrite",source:$s,deployed_hash:$h}')"
        ;;
      new_file)
        deploy_overwrite_file "$src" "$dest" "${FILE_SOURCE[$dest]}"
        echo "      new: $dest"
        ;;
      to_remove)
        remove_managed_file "$dest"
        echo "      removed: $dest"
        ;;
      merge)
        if [[ -f "$src" ]]; then
          [[ -f "$dest" ]] || { mkdir -p "$(dirname "$dest")"; echo '{}' > "$dest"; }
          deploy_merge_file "$src" "$dest" "${FILE_SOURCE[$dest]}"
          echo "      merged: $dest"
        fi
        ;;
    esac
  done

  manifest_stage_set_top blueprint_commit "$NEW_COMMIT"
  local origin
  origin=$(git -C "$AICODING_BLUEPRINT_CLONE" remote get-url origin 2>/dev/null || echo unknown)
  manifest_stage_set_top blueprint_origin "$origin"
}

apply_all
manifest_stage_commit

echo
echo "Manifest now at blueprint $NEW_COMMIT."
