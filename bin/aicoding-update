#!/usr/bin/env bash
set -euo pipefail

# Resolve the blueprint directory: prefer the existing clone at
# $AICODING_BLUEPRINT_CLONE (default /tmp/aicoding); refresh it from git.
# Source the library from the resolved blueprint dir.

SCRIPT_REAL=$(readlink -f "$0")
SCRIPT_DIR=$(dirname "$(dirname "$SCRIPT_REAL")")

: "${AICODING_BLUEPRINT_CLONE:=/tmp/aicoding}"
: "${AICODING_BLUEPRINT_REMOTE:=https://github.com/vossiman/aiCodingBaseSetup}"

ARG_DRY_RUN=0
ARG_YES=0
for arg in "$@"; do
  case "$arg" in
    --dry-run) ARG_DRY_RUN=1 ;;
    --yes)     ARG_YES=1 ;;
    -h|--help)
      cat <<EOF
Usage: aicoding-update [--dry-run] [--yes]
  --dry-run  Show what would change, write nothing.
  --yes      Skip the y/N confirm prompt.
EOF
      exit 0
      ;;
    *) echo "unknown argument: $arg" >&2; exit 2 ;;
  esac
done

refresh_blueprint() {
  if [[ -d "$AICODING_BLUEPRINT_CLONE/.git" ]]; then
    # Only hard-reset if we could actually fetch fresh refs. Otherwise
    # leave the working tree alone — in particular, never wipe local
    # state on the fallback path, which would clobber test setups and
    # any user-staged blueprint experiments.
    if git -C "$AICODING_BLUEPRINT_CLONE" fetch --quiet origin 2>/dev/null; then
      git -C "$AICODING_BLUEPRINT_CLONE" reset --hard --quiet origin/main 2>/dev/null || true
    else
      echo "could not fetch blueprint — using cached clone" >&2
    fi
  elif [[ ! -d "$AICODING_BLUEPRINT_CLONE" ]]; then
    git clone --quiet "$AICODING_BLUEPRINT_REMOTE" "$AICODING_BLUEPRINT_CLONE"
  fi
  # We always source from the clone, so its current state is what's used.
}

refresh_blueprint
. "$AICODING_BLUEPRINT_CLONE/lib/blueprint-deploy.sh"

# Secrets need to be in the environment before any deploy_*_substituted call,
# otherwise the substituted output strips placeholders to empty strings and
# our deployed file would lose any value previously written by install.sh.
# load_secrets_env is a no-op if no .secrets.env exists (e.g. test runs).
load_secrets_env

if [[ ! -f "$AICODING_MANIFEST" ]]; then
  echo "aicoding-update: no manifest at $AICODING_MANIFEST" >&2
  echo "Run install.sh first to provision this container." >&2
  exit 1
fi

# Refuse to operate on a manifest written by a future schema we don't know.
manifest_check_schema

OLD_COMMIT=$(jq -r '.blueprint_commit // "unknown"' "$AICODING_MANIFEST")
NEW_COMMIT=$(git -C "$AICODING_BLUEPRINT_CLONE" rev-parse --short HEAD 2>/dev/null || echo unknown)

echo "Blueprint: ${OLD_COMMIT} -> ${NEW_COMMIT}"

# Classification: walk union of manifest entries and blueprint inventory.
declare -A FILE_MODE FILE_SOURCE
declare -A BUCKETS

# Marker strings come from the library — keep this script free of duplicate
# managed-file declarations (install.sh and aicoding-update used to drift).
BASHRC_DEST=$(managed_bashrc_path)

classify_all() {
  local entry dest mode source
  # Overwrite-mode files from the blueprint inventory.
  while IFS='|' read -r dest mode source; do
    [[ -z "$dest" ]] && continue
    FILE_MODE[$dest]=$mode
    FILE_SOURCE[$dest]=$source
    BUCKETS[$dest]=$(classify_file "$dest" "$AICODING_BLUEPRINT_CLONE/$source" "$mode")
  done < <(managed_inventory_overwrite)

  # Merge-mode files from the blueprint inventory.
  while IFS='|' read -r dest mode source; do
    [[ -z "$dest" ]] && continue
    FILE_MODE[$dest]=$mode
    FILE_SOURCE[$dest]=$source
    BUCKETS[$dest]=$(classify_file "$dest" "$AICODING_BLUEPRINT_CLONE/$source" "$mode")
  done < <(managed_inventory_merge)

  # The single marker_block file (~/.bashrc) — classified by block hash.
  FILE_MODE[$BASHRC_DEST]=marker_block
  FILE_SOURCE[$BASHRC_DEST]="(composed)"
  BUCKETS[$BASHRC_DEST]=$(classify_marker_block "$BASHRC_DEST")

  # Enumerate skills in blueprint clone.
  local skill_dir skill_name
  for skill_dir in "$AICODING_BLUEPRINT_CLONE/skills"/*/; do
    [[ ! -d "$skill_dir" ]] && continue
    skill_name=$(basename "$skill_dir")
    dest="$HOME/.claude/skills/$skill_name/SKILL.md"
    source="skills/$skill_name/SKILL.md"
    FILE_MODE[$dest]=overwrite
    FILE_SOURCE[$dest]=$source
    BUCKETS[$dest]=$(classify_file "$dest" "$AICODING_BLUEPRINT_CLONE/$source" overwrite)
  done

  # Files in manifest but absent from blueprint inventory → to_remove.
  # Done LAST so any blueprint-tracked entry above wins over manifest sweep.
  local manifest_files
  manifest_files=$(jq -r '.files | keys[]' "$AICODING_MANIFEST")
  while IFS= read -r dest; do
    [[ -z "$dest" ]] && continue
    [[ -z "${FILE_MODE[$dest]:-}" ]] && BUCKETS[$dest]=to_remove
  done <<<"$manifest_files"
  # Ensure a clean exit code under `set -e` — the while loop above ends with
  # whatever the last short-circuit `&&` returned (often 1 when nothing was
  # appended), which would otherwise propagate up and abort the script.
  return 0
}

classify_all

# Summary tallies for the dry-run output.
declare -A COUNT
COUNT[up_to_date]=0
COUNT[will_update]=0
COUNT[drifted_but_aligned]=0
COUNT[drifted_and_updating]=0
COUNT[restore]=0
COUNT[new_file]=0
COUNT[to_remove]=0
COUNT[merge]=0

for dest in "${!BUCKETS[@]}"; do
  b=${BUCKETS[$dest]}
  COUNT[$b]=$(( ${COUNT[$b]} + 1 ))
done

if [[ $ARG_DRY_RUN -eq 1 ]]; then
  for b in up_to_date will_update drifted_but_aligned drifted_and_updating restore new_file to_remove merge; do
    echo "  ${COUNT[$b]} $b"
  done
  exit 0
fi

print_summary() {
  echo
  echo "  ${COUNT[up_to_date]} up to date"

  if (( COUNT[will_update] > 0 )); then
    echo "  ${COUNT[will_update]} will update         (no drift):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == will_update ]] && echo "      $dest"
    done
  fi

  if (( COUNT[restore] > 0 )); then
    echo "  ${COUNT[restore]} restore             (file missing, will be restored from blueprint):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == restore ]] && echo "      $dest"
    done
  fi

  if (( COUNT[drifted_and_updating] > 0 )); then
    echo "  ${COUNT[drifted_and_updating]} needs your decision (you've modified, blueprint also changed):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} != drifted_and_updating ]] && continue
      echo "      $dest"
      # marker_block has no on-disk blueprint source path; skip the diff there.
      if [[ "${FILE_MODE[$dest]:-overwrite}" != "marker_block" ]]; then
        local src="$AICODING_BLUEPRINT_CLONE/${FILE_SOURCE[$dest]}"
        # Defensive 2>/dev/null: after the restore-bucket split, both sides
        # should exist here, but if classify_file ever misroutes, we don't
        # want `diff: <path>: No such file or directory` leaking to stderr.
        diff -u --label "your version" --label "blueprint version" "$dest" "$src" 2>/dev/null \
          | sed 's/^/        /' || true
      fi
    done
  fi

  if (( COUNT[to_remove] > 0 )); then
    echo "  ${COUNT[to_remove]} to remove           (no longer in blueprint):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == to_remove ]] && echo "      $dest"
    done
  fi

  if (( COUNT[new_file] > 0 )); then
    echo "  ${COUNT[new_file]} new files           (will be deployed):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == new_file ]] && echo "      $dest"
    done
  fi

  if (( COUNT[merge] > 0 )); then
    echo "  ${COUNT[merge]} merge target(s)     (will re-merge, additions preserved):"
    for dest in "${!BUCKETS[@]}"; do
      [[ ${BUCKETS[$dest]} == merge ]] && echo "      $dest"
    done
  fi

  echo
}

print_summary

# Nothing actionable?
if (( COUNT[will_update] + COUNT[drifted_and_updating] + COUNT[restore] + COUNT[new_file] + COUNT[to_remove] + COUNT[merge] == 0 )); then
  echo "Nothing to do."
  exit 0
fi

if [[ $ARG_YES -ne 1 ]]; then
  # `read -p` only prints the prompt to a terminal; for piped/redirected
  # stdin (tests, CI) we still want the prompt text visible in the log.
  printf 'Apply? [y/N] '
  read -r answer
  case "$answer" in
    y|Y|yes) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

manifest_stage_begin

backup_drifted() {
  local dest=$1
  # Defensive: a restore-bucket file won't reach this codepath, but if a
  # future caller misroutes a missing file here, skip silently rather than
  # producing a cp error and a misleading "backup:" line.
  [ -e "$dest" ] || return 0
  local stamp
  stamp=$(date +%Y%m%d-%H%M%S)
  cp "$dest" "$dest.bak.$stamp"
  echo "      backup: $dest.bak.$stamp"
}

# _apply_deploy <mode> <dest> <src> — dispatch to the correct deploy
# primitive based on the file's mode. Used for will_update / new_file /
# drifted_and_updating cases; substitutes secrets on overwrite/merge so
# that {{HOME}} / {{*_API_KEY}} placeholders never reach disk.
_apply_deploy() {
  local mode=$1 dest=$2 src=$3
  case "$mode" in
    overwrite)
      deploy_overwrite_file_substituted "$src" "$dest" "${FILE_SOURCE[$dest]}"
      ;;
    merge)
      [[ -f "$dest" ]] || { mkdir -p "$(dirname "$dest")"; echo '{}' > "$dest"; }
      deploy_merge_file_substituted "$src" "$dest" "${FILE_SOURCE[$dest]}"
      ;;
    marker_block)
      deploy_marker_block "$dest" \
        "$(managed_bashrc_block_body)" \
        "$(managed_marker_block_start)" "$(managed_marker_block_end)"
      ;;
  esac
}

apply_all() {
  local dest src bucket mode
  for dest in "${!BUCKETS[@]}"; do
    bucket=${BUCKETS[$dest]}
    mode=${FILE_MODE[$dest]:-overwrite}
    src="$AICODING_BLUEPRINT_CLONE/${FILE_SOURCE[$dest]:-}"

    case "$bucket" in
      up_to_date)
        : ;;
      will_update)
        _apply_deploy "$mode" "$dest" "$src"
        echo "      updated: $dest"
        ;;
      drifted_and_updating)
        # marker_block carries user-managed content too; back up on drift.
        if [[ -e "$dest" ]]; then
          backup_drifted "$dest"
        fi
        _apply_deploy "$mode" "$dest" "$src"
        echo "      updated (with backup): $dest"
        ;;
      restore)
        # File tracked in manifest, source present in blueprint, but the
        # file isn't on disk. No backup attempt (nothing to back up); just
        # re-deploy and announce it cleanly.
        _apply_deploy "$mode" "$dest" "$src"
        echo "      restored: $dest"
        ;;
      drifted_but_aligned)
        # Refresh hash only — content on disk already matches blueprint.
        if [[ "$mode" = "marker_block" ]]; then
          local h
          h=$(compute_block_hash "$dest" \
              "$(managed_marker_block_start)" "$(managed_marker_block_end)")
          manifest_set_file "$dest" \
            "$(jq -n --arg s "$(managed_marker_block_start)" \
                     --arg e "$(managed_marker_block_end)" \
                     --arg h "$h" \
                '{mode:"marker_block",source:"(composed)",marker_start:$s,marker_end:$e,deployed_block_hash:$h}')"
        else
          local h
          h=$(compute_hash "$dest")
          manifest_set_file "$dest" \
            "$(jq -n --arg s "${FILE_SOURCE[$dest]}" --arg h "$h" \
                '{mode:"overwrite",source:$s,deployed_hash:$h}')"
        fi
        ;;
      new_file)
        _apply_deploy "$mode" "$dest" "$src"
        echo "      new: $dest"
        ;;
      to_remove)
        remove_managed_file "$dest"
        echo "      removed: $dest"
        ;;
      merge)
        # Classification bucket for merge-mode files (always 'merge', never
        # 'will_update' etc). Identical handling to will_update via mode.
        if [[ -f "$src" ]]; then
          _apply_deploy merge "$dest" "$src"
          echo "      merged: $dest"
        fi
        ;;
    esac
  done

  manifest_stage_set_top blueprint_commit "$NEW_COMMIT"
  local origin
  origin=$(git -C "$AICODING_BLUEPRINT_CLONE" remote get-url origin 2>/dev/null || echo unknown)
  manifest_stage_set_top blueprint_origin "$origin"
}

apply_all
manifest_stage_commit

echo
echo "Manifest now at blueprint $NEW_COMMIT."
