#!/usr/bin/env bash
# aiCodingBaseSetup — git credential helper: file-based GH_TOKEN fallback.
# Managed by install.sh (deployed to ~/.local/bin/git-credential-aicoding).
#
# Why: agent CLIs strip env vars whose names contain KEY/SECRET/TOKEN from
# the commands they spawn (codex's default shell_environment_policy), so
# `gh auth git-credential` — which reads GH_TOKEN from the environment —
# fails for a `git push` run inside such a session. This helper reads the
# token from ~/.aicodingsetup/.secrets.env instead. It is registered AFTER
# the gh helper, so git only consults it when gh produced no credentials.
#
# Credential-helper protocol (git-scm.com/docs/gitcredentials): git passes
# the action as $1 and key=value pairs on stdin. Only `get` for
# https/github.com is answered; everything else exits 0 silently so git
# moves on.
set -u

[ "${1:-}" = "get" ] || exit 0

host="" protocol=""
while IFS= read -r line; do
  [ -z "$line" ] && break
  case "$line" in
    host=*) host=${line#host=} ;;
    protocol=*) protocol=${line#protocol=} ;;
  esac
done
[ "$host" = "github.com" ] && [ "$protocol" = "https" ] || exit 0

secrets="${AICODING_SECRETS_FILE:-$HOME/.aicodingsetup/.secrets.env}"
[ -r "$secrets" ] || exit 0

token=$(sed -n 's/^GH_TOKEN=//p' "$secrets" | tail -1)
# Tolerate quoted values in the hand-maintained file.
token=${token%\"}; token=${token#\"}
token=${token%\'}; token=${token#\'}
[ -n "$token" ] || exit 0

printf 'username=x-access-token\npassword=%s\n' "$token"
